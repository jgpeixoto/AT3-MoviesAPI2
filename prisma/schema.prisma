generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id           Int             @id @default(autoincrement())
  title        String
  description  String
  releaseYear  Int
  genre        String
  duration     Int
  avgRating    Decimal         @default(0) @db.Decimal(3, 1)
  totalRatings Int             @default(0)
  users        User[]
  movieList    UserMovieList[]
  ratings      Rating[]
  
  @@unique([title, releaseYear])
  @@map("movies")
}

model User {
  id        Int             @id @default(autoincrement())
  name      String
  email     String          @unique
  password  String   
  movies    Movie[]
  movieList UserMovieList[]
  ratings   Rating[]

  @@map("users")
}

model UserMovieList {
  id      Int   @id @default(autoincrement())
  userId  Int
  movieId Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}

model Rating {
  id        Int      @id @default(autoincrement())
  score     Decimal  @default(0) @db.Decimal(3, 1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int
  movieId   Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
  @@map("ratings")
}
